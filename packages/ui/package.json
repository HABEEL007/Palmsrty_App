    "@storybook/react-vite": "^8.0.0",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "lucide-react": "^0.363.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^8.0.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  },
  "dependencies": {
    "clsx": "^2.1.0",
