{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "VITE_API_URL",
    "VITE_SUPABASE_URL",
    "VITE_SUPABASE_ANON_KEY",
    "SUPABASE_URL",
    "SUPABASE_ANON_KEY",
    "SUPABASE_ANON_KEY",
    "GEMINI_API_KEY",
    "CLOUDINARY_URL",
    "UPSTASH_REDIS_URL",
    "UPSTASH_REDIS_TOKEN",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "PORT",
    "GATEWAY_PORT",
    "AI_SERVICE_PORT",
    "IMAGE_SERVICE_PORT",
    "READING_SERVICE_PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist/index.js", ".next/**", "storybook-static/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts", "test/**/*.tsx"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
